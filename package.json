{
  "name": "markdown-agent-comments",
  "version": "0.1.3",
  "description": "@agent comments in markdown",
  "type": "module",
  "bin": {
    "mdac": "cli/bin.js"
  },
  "files": [
    "cli",
    "demo",
    "skill",
    "!demo/runs/**",
    "!skill/**/.generated/**",
    "!skill/**/runs/**",
    "docs/PRD.md",
    "docs/naming.md",
    "NUX.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun run test:core && bun run test:cli && bun run test:demo && bun run test:eval",
    "test:core": "bun test skill/markdown-agent-comments/test/*.test.js",
    "test:cli": "bun test cli/test/*.test.js",
    "test:demo": "bun test demo/test/*.test.js",
    "test:eval": "bun test skill/markdown-agent-comments/eval/test/*.test.js",
    "test:review": "bun run test && node demo/run-skill.js",
    "build:binaries": "bun build --compile --target=bun-darwin-arm64 cli/compiled-entry.js --outfile dist/mdac-darwin-arm64 && bun build --compile --target=bun-darwin-x64 cli/compiled-entry.js --outfile dist/mdac-darwin-x64",
    "eval:prepare": "node skill/markdown-agent-comments/eval/prepare.js",
    "eval:verify": "node skill/markdown-agent-comments/eval/verify.js",
    "eval:judge": "node skill/markdown-agent-comments/eval/judge.js"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://mdac.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smcllns/markdown-agent-comments.git"
  },
  "license": "MIT"
}
